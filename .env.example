# 阿里云 DashScope API Key（ASR + LLM 必填）
DASHSCOPE_API_KEY=sk-your-key-here

# 可选：同步/异步 ASR 模型
# QWEN_ASR_MODEL=qwen3-asr-flash
# QWEN_ASR_FILE_MODEL=qwen3-asr-flash-filetrans

# 可选：API 端点
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 可选：覆盖 config.yaml 中的 LLM 模型
# PODCAST_LLM_MODEL=qwen-max
